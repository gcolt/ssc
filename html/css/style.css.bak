*,
*::before,
*::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    /*  outline: 3px solid lime; */
}

:root {
    interpolate-size: allow-keywords;
}

html {
    background-color: lightgoldenrodyellow;
    /*overflow: hidden;*/
}

body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 100vh;
    padding-top: 14ch; /* Increased to compensate for fixed header + nav */
}

.heading {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    background-color: lightgoldenrodyellow; /* Match html background */
}

.el {
    color: #002800;
    text-align: center;
    font-size: 4vw;
    font-weight: 900;
    font-stretch: expanded;
    padding-block: 0.5ch;
}

a:hover {
    color: gray;
}

a[href$=".pdf"]::after {
    content: " (pdf)";
    font-size: 0.8rem;
    font-weight: bold;
    color: #555;
    vertical-align: super;
    margin-left: 4px;
}

a:focus-visable,
summary:focus {
    outline: 3px solid #ffbf47; /* Bright gold for high visibility */
    outline-offset: 2px;
}

li a:hover {
    color: black;
    /*outline: 2px solid lightgray;*/
}

.grid-container {
    display: grid;
    /* height: 100vh; /* Critical: Locks the container to the screen height */ */
    grid-template-rows: 14ch 1fr 30px; /* Header+Nav, Body (flexible), Footer */
    grid-template-columns: 1fr;
}

main {
    display: grid;
    /* height: 100vh; /* Critical: Locks the container to the screen height */ */
    grid-template-rows: 60px 1fr 60px; /* Header, Body (flexible), Footer */
    grid-template-columns: 1fr;
}

.container {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 3fr;
    grid-auto-rows: minmax(100px, auto);
}

nav {
    text-align: center;
    background-color: #445e53;
    /*justify-content: space-evenly;*/
    justify-content: space-between 5ch;;
    /* position: fixed;  -- Moved to .heading */
    /* top: 0;           -- Moved to .heading */
    width: 100%; /* Ensure header spans full width */
    z-index: 1000;
}

nav div {
    color: white;
    font-family: system-ui, sans-serif;
    font-size: 2vw;
    font-weight: 700;
    text-decoration: none;
}

nav li {
    display: inline-block;
}

nav li a {
    color: white;
    font-family: system-ui, sans-serif;
    font-size: 2vw;
    font-weight: 700;
    text-decoration: none;
}

.box {
    background-color: bisque;
    color: black;
    font-size: 1.1rem;
    padding: 0.5rem;
    justify-content: center;
    min-height: 200px;
}

.responsive {
    width: 100%;
    height: auto;
}

figure {
    grid-column: span 2;
}
figcaption {
    font-size: 0.2rem;
}
article {
    font-size: 1.1rem;
    margin-left: 2rem;
}
aside {
    padding-left: 15px;
}

summary {
    list-style-position: outside;
}

summary::marker {
    font-size: 0.9rem;
    color: gray;
}

details li {
    padding-block: 0.5rem;
    display: block;
    font-weight: 600;
}

footer {
    grid-column: span 2;
    text-align: center;
}

/* Target the paragraphs and aside within your #about section */
#about p,
#about aside {
    margin-bottom: 1.5rem; /* Adjust this value for more/less space */
}

/* Remove margin from the last element so it doesn't create extra bottom space */
#about > *:last-child {
    margin-bottom: 0;
}

/* Optional: Style the summary to look professional */
summary h3 {
    display: inline; /* Keeps the heading on the same line as the arrow */
    cursor: pointer;
    font-size: 1.1rem;
}
